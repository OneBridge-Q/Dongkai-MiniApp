page {
  height: 100%;
  background: #06261d;
}

.page {
  position: relative;
  height: 100vh;
  padding:
    calc(env(safe-area-inset-top) + 24rpx)
    40rpx
    calc(env(safe-area-inset-bottom) + 30rpx);
  box-sizing: border-box;
  overflow: hidden;
  background:
    radial-gradient(
      circle at 90% 6%,
      rgba(80, 154, 94, 0.22) 0,
      rgba(80, 154, 94, 0) 28%
    ),
    linear-gradient(
      180deg,
      #031f18 0%,
      #062b20 50%,
      #0b3b29 100%
    );
}

.top-bar {
  position: relative;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.07);
  color: #fff0bd;
  font-size: 52rpx;
  line-height: 1;
}

.top-title {
  color: rgba(239, 244, 238, 0.84);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.top-placeholder {
  width: 62rpx;
}

.mission-header {
  position: relative;
  z-index: 4;
  margin-top: 22rpx;
  text-align: center;
}

.mission-label {
  color: #e6c75d;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 7rpx;
}

.mission-title {
  margin-top: 8rpx;
  color: #f8dc82;
  font-size: 50rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
}

.mission-card {
  position: relative;
  z-index: 4;
  margin-top: 28rpx;
  padding: 30rpx 34rpx 32rpx;
  border: 2rpx solid rgba(222, 200, 111, 0.25);
  border-radius: 38rpx;
  background: rgba(34, 76, 61, 0.68);
  box-sizing: border-box;
  text-align: center;
}

.character-area {
  position: relative;
  width: 220rpx;
  height: 120rpx;
  margin: 0 auto;
}

.character-glow {
  position: absolute;
  top: 5rpx;
  left: 50%;
  width: 160rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(210, 224, 113, 0.08);
  transform: translateX(-50%);
  filter: blur(16rpx);
}

.ant {
  position: relative;
  z-index: 2;
  font-size: 88rpx;
  line-height: 92rpx;
  text-align: center;
}

.leaf-platform {
  position: absolute;
  z-index: 1;
  bottom: 0;
  left: 50%;
  width: 170rpx;
  height: 32rpx;
  border-radius: 100% 18% 100% 22%;
  background: linear-gradient(
    90deg,
    #477d43 0%,
    #78a956 52%,
    #3f7542 100%
  );
  transform: translateX(-50%) rotate(-2deg);
}

.character-name {
  margin-top: 10rpx;
  color: #fff0bd;
  font-size: 42rpx;
  font-weight: 800;
}

.dialogue {
  margin-top: 22rpx;
  padding: 20rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(3, 33, 25, 0.34);
  color: rgba(245, 248, 244, 0.86);
  font-size: 28rpx;
  line-height: 1.7;
}

.mission-description {
  margin-top: 20rpx;
  color: rgba(244, 248, 243, 0.88);
  font-size: 29rpx;
  line-height: 1.6;
}

.clue-card {
  position: relative;
  z-index: 4;
  margin-top: 22rpx;
  padding: 24rpx 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.06);
}

.clue-title {
  color: #fff0bd;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.clue-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.clue-tag {
  padding: 14rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(246, 207, 77, 0.12);
  color: rgba(237, 242, 235, 0.86);
  font-size: 24rpx;
}

.safety-tip {
  margin-top: 18rpx;
  color: rgba(190, 211, 190, 0.64);
  font-size: 23rpx;
  text-align: center;
}

.action-area {
  position: relative;
  z-index: 10;
  margin-top: 26rpx;
  text-align: center;
}

.start-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86%;
  height: 100rpx;
  margin: 0 auto;
  border-radius: 52rpx;
  background: linear-gradient(
    135deg,
    #f6cf4d 0%,
    #ffe27a 52%,
    #efc84e 100%
  );
  color: #123f30;
  font-size: 32rpx;
  font-weight: 750;
  box-shadow: 0 16rpx 36rpx rgba(243, 205, 76, 0.2);
}

.start-button:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.safety-hint {
  margin-top: 18rpx;
  color: rgba(190, 211, 190, 0.56);
  font-size: 22rpx;
}

.background-glow {
  position: absolute;
  z-index: 1;
  border-radius: 50%;
  filter: blur(40rpx);
  pointer-events: none;
}

.glow-top {
  top: -120rpx;
  right: -100rpx;
  width: 380rpx;
  height: 380rpx;
  background: rgba(68, 139, 84, 0.15);
}

.glow-bottom {
  bottom: -100rpx;
  left: -150rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(108, 156, 83, 0.1);
}

@media screen and (max-height: 700px) {
  .page {
    padding-top: calc(env(safe-area-inset-top) + 14rpx);
  }

  .mission-header {
    margin-top: 12rpx;
  }

  .mission-title {
    font-size: 44rpx;
  }

  .mission-card {
    margin-top: 18rpx;
    padding-top: 22rpx;
    padding-bottom: 24rpx;
  }

  .character-area {
    height: 104rpx;
  }

  .clue-card {
    margin-top: 16rpx;
    padding-top: 18rpx;
    padding-bottom: 18rpx;
  }

  .action-area {
    margin-top: 18rpx;
  }

  .start-button {
    height: 88rpx;
  }
}