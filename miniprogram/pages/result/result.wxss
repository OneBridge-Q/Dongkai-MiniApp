page {
  min-height: 100%;
  background: #06261d;
}

.page {
  position: relative;
  min-height: 100vh;
  padding:
    calc(env(safe-area-inset-top) + 84rpx)
    42rpx
    calc(env(safe-area-inset-bottom) + 54rpx);
  box-sizing: border-box;
  background:
    radial-gradient(
      circle at 50% 14%,
      rgba(246, 211, 94, 0.14),
      rgba(246, 211, 94, 0) 28%
    ),
    linear-gradient(
      180deg,
      #031f18 0%,
      #062b20 52%,
      #0b3b29 100%
    );
}

.success-label {
  color: #e1c457;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 8rpx;
}

.success-title {
  margin-top: 18rpx;
  color: #ffe49a;
  font-size: 52rpx;
  font-weight: 800;
  text-align: center;
}

.result-card {
  margin-top: 54rpx;
  padding: 28rpx 32rpx 42rpx;
  border: 2rpx solid rgba(224, 198, 104, 0.28);
  border-radius: 42rpx;
  background: rgba(33, 76, 61, 0.72);
  box-shadow: 0 28rpx 70rpx rgba(0, 0, 0, 0.22);
}

.image-wrap {
  position: relative;
  height: 520rpx;
  overflow: hidden;
  border-radius: 28rpx;
}

.result-image {
  width: 100%;
  height: 100%;
}

.rarity-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(6, 43, 32, 0.82);
  color: #f5dc80;
  font-size: 23rpx;
  font-weight: 700;
}

.species-name {
  margin-top: 34rpx;
  color: #fff0bd;
  font-size: 48rpx;
  font-weight: 800;
  text-align: center;
}

.species-title {
  margin-top: 12rpx;
  color: rgba(203, 222, 199, 0.7);
  font-size: 26rpx;
  text-align: center;
}

.divider {
  height: 1rpx;
  margin: 34rpx 0;
  background:
    linear-gradient(
      90deg,
      rgba(255, 255, 255, 0),
      rgba(222, 200, 111, 0.22),
      rgba(255, 255, 255, 0)
    );
}

.fact {
  color: rgba(240, 246, 238, 0.82);
  font-size: 28rpx;
  line-height: 1.8;
  text-align: center;
}

.reward-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 38rpx;
  padding: 28rpx 0;
  border-radius: 26rpx;
  background: rgba(5, 36, 27, 0.34);
}

.reward-item {
  flex: 1;
  text-align: center;
}

.reward-value {
  color: #f6d761;
  font-size: 38rpx;
  font-weight: 800;
}

.reward-label {
  margin-top: 8rpx;
  color: rgba(209, 224, 206, 0.62);
  font-size: 23rpx;
}

.reward-divider {
  width: 1rpx;
  height: 74rpx;
  background: rgba(255, 255, 255, 0.1);
}

.action-area {
  margin-top: 42rpx;
  padding-bottom: 30rpx;
  text-align: center;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88%;
  height: 108rpx;
  margin: 0 auto;
  border-radius: 56rpx;
  background:
    linear-gradient(
      135deg,
      #f6cf4d,
      #ffe27a 52%,
      #efc84e
    );
  color: #123f30;
  font-size: 32rpx;
  font-weight: 750;
  box-shadow: 0 18rpx 42rpx rgba(243, 205, 76, 0.2);
}

.secondary-button {
  margin-top: 22rpx;
  color: rgba(207, 222, 204, 0.62);
  font-size: 26rpx;
}