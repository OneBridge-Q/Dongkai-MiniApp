page {
  min-height: 100%;
  background: #06261d;
}

.page {
  position: relative;
  height: 100vh;
  padding:
    calc(env(safe-area-inset-top) + 34rpx)
    42rpx
    calc(env(safe-area-inset-bottom) + 100rpx);
  box-sizing: border-box;
  overflow-y: auto;
  background:
    radial-gradient(
      circle at 90% 7%,
      rgba(80, 154, 94, 0.22) 0,
      rgba(80, 154, 94, 0) 28%
    ),
    radial-gradient(
      circle at 8% 78%,
      rgba(92, 147, 78, 0.15) 0,
      rgba(92, 147, 78, 0) 26%
    ),
    linear-gradient(
      180deg,
      #031f18 0%,
      #062b20 50%,
      #0b3b29 100%
    );
}

/* 顶部导航 */

.top-bar {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.07);
  color: #fff0bd;
  font-size: 58rpx;
  line-height: 1;
}

.top-title {
  color: rgba(239, 244, 238, 0.84);
  font-size: 29rpx;
  font-weight: 600;
  letter-spacing: 5rpx;
}

.top-placeholder {
  width: 68rpx;
}

/* 当前任务 */

.mission-info {
  position: relative;
  z-index: 5;
  margin-top: 36rpx;
  text-align: center;
}

.mission-label {
  color: #e6c75d;
  font-size: 23rpx;
  font-weight: 700;
  letter-spacing: 7rpx;
}

.mission-name {
  margin-top: 14rpx;
  color: #fff0bd;
  font-size: 36rpx;
  font-weight: 750;
  line-height: 1.45;
}

/* 拍摄卡片 */

.camera-card,
.preview-card {
  position: relative;
  z-index: 5;
  width: 100%;
  margin-top: 42rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(222, 200, 111, 0.26);
  border-radius: 42rpx;
  background: rgba(31, 73, 58, 0.68);
  overflow: hidden;
  box-shadow: 0 26rpx 70rpx rgba(0, 0, 0, 0.2);
}

.camera-card {
  padding: 30rpx;
}

.scan-frame {
  position: relative;
  height: 440rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(
      circle at center,
      rgba(105, 164, 106, 0.16),
      rgba(4, 34, 26, 0.32) 70%
    );
}

.camera-content {
  display: flex;
  height: 100%;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.camera-icon {
  color: #f4d35e;
  font-size: 100rpx;
  line-height: 1;
  text-shadow: 0 0 34rpx rgba(244, 211, 94, 0.18);
}

.camera-title {
  margin-top: 30rpx;
  color: #fff0bd;
  font-size: 36rpx;
  font-weight: 750;
}

.camera-description {
  margin-top: 24rpx;
  color: rgba(234, 241, 232, 0.76);
  font-size: 28rpx;
  line-height: 1.8;
  text-align: center;
}

/* 扫描框四角 */

.corner {
  position: absolute;
  width: 62rpx;
  height: 62rpx;
  border-color: rgba(246, 207, 77, 0.72);
  pointer-events: none;
}

.corner-top-left {
  top: 24rpx;
  left: 24rpx;
  border-top: 5rpx solid;
  border-left: 5rpx solid;
  border-radius: 12rpx 0 0 0;
}

.corner-top-right {
  top: 24rpx;
  right: 24rpx;
  border-top: 5rpx solid;
  border-right: 5rpx solid;
  border-radius: 0 12rpx 0 0;
}

.corner-bottom-left {
  bottom: 24rpx;
  left: 24rpx;
  border-bottom: 5rpx solid;
  border-left: 5rpx solid;
  border-radius: 0 0 0 12rpx;
}

.corner-bottom-right {
  right: 24rpx;
  bottom: 24rpx;
  border-right: 5rpx solid;
  border-bottom: 5rpx solid;
  border-radius: 0 0 12rpx 0;
}

/* 拍摄提示 */

.tips {
  margin-top: 26rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  min-height: 56rpx;
}

.tip-number {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: rgba(246, 207, 77, 0.14);
  color: #f6cf4d;
  font-size: 22rpx;
  font-weight: 700;
}

.tip-text {
  color: rgba(226, 236, 224, 0.72);
  font-size: 26rpx;
  line-height: 1.5;
}

/* 图片预览 */

.preview-card {
  height: 650rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-mask {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 34rpx;
  background:
    linear-gradient(
      180deg,
      rgba(4, 30, 24, 0),
      rgba(4, 30, 24, 0.9)
    );
}

.preview-status {
  color: #fff0bd;
  font-size: 29rpx;
  font-weight: 600;
  text-align: center;
}

/* 底部操作区 */

.action-area {
  position: relative;
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 42rpx;
  padding-bottom: 60rpx;
}

.capture-button,
.confirm-button {
  position: relative;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86%;
  height: 112rpx;
  margin: 0 auto;
  padding: 0;
  border: none;
  border-radius: 58rpx;
  background:
    linear-gradient(
      135deg,
      #f6cf4d 0%,
      #ffe27a 52%,
      #efc84e 100%
    );
  color: #123f30;
  font-size: 34rpx;
  font-weight: 750;
  line-height: 112rpx;
  box-shadow:
    0 18rpx 42rpx rgba(243, 205, 76, 0.22),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.35);
}

.capture-button::after,
.confirm-button::after,
.retry-button::after {
  border: none;
}

.capture-button:active,
.confirm-button:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.capture-circle {
  width: 32rpx;
  height: 32rpx;
  margin-right: 18rpx;
  border: 5rpx solid #123f30;
  border-radius: 50%;
  box-sizing: border-box;
}

.capture-text {
  font-size: 34rpx;
  font-weight: 750;
}

.retry-button {
  height: 76rpx;
  margin-top: 18rpx;
  padding: 0 36rpx;
  border: none;
  background: transparent;
  color: rgba(228, 237, 226, 0.75);
  font-size: 28rpx;
  line-height: 76rpx;
}

.safety-hint {
  margin-top: 24rpx;
  color: rgba(190, 211, 190, 0.56);
  font-size: 23rpx;
  line-height: 1.5;
  text-align: center;
}

/* 背景光晕 */

.background-glow {
  position: absolute;
  z-index: 1;
  border-radius: 50%;
  filter: blur(40rpx);
  pointer-events: none;
}

.glow-top {
  top: -130rpx;
  right: -110rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(68, 139, 84, 0.15);
}

.glow-bottom {
  bottom: -100rpx;
  left: -150rpx;
  width: 420rpx;
  height: 420rpx;
  background: rgba(108, 156, 83, 0.12);
}

/* 小屏幕适配 */

@media screen and (max-height: 700px) {
  .page {
    padding-top: calc(env(safe-area-inset-top) + 24rpx);
  }

  .mission-info {
    margin-top: 24rpx;
  }

  .camera-card,
  .preview-card {
    margin-top: 30rpx;
  }

  .scan-frame {
    height: 360rpx;
  }

  .camera-icon {
    font-size: 84rpx;
  }

  .camera-title {
    margin-top: 22rpx;
    font-size: 32rpx;
  }

  .action-area {
    margin-top: 32rpx;
  }
}