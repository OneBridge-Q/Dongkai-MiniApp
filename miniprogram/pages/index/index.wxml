<view class="page">
  <!-- 背景光晕 -->
  <view class="background-glow glow-top"></view>
  <view class="background-glow glow-bottom"></view>

  <!-- 萤火虫 -->
  <view class="firefly firefly-1"></view>
  <view class="firefly firefly-2"></view>
  <view class="firefly firefly-3"></view>
  <view class="firefly firefly-4"></view>
  <view class="firefly firefly-5"></view>

  <!-- 顶部标题 -->
  <view class="header">
    <view class="brand-row">
      <view class="brand-decoration">‹</view>
      <view class="brand">洞 开</view>
      <view class="brand-decoration">›</view>
    </view>

    <view class="subtitle-row">
      <view class="mini-leaf">◆</view>
      <view class="subtitle">少年自然探索计划</view>
      <view class="mini-leaf">◆</view>
    </view>
  </view>

  <!-- 故事卡片 -->
  <view class="story-card">
    <view class="character-area">
      <view class="character-glow"></view>
      <view class="ant">🐜</view>
      <view class="leaf-platform"></view>
    </view>

    <view class="headline">
      世界正在失去记忆
    </view>

    <view class="story-section">
      <view class="story-line">森林里的昆虫们，</view>
      <view class="story-line">正在慢慢忘记自己的名字。</view>
    </view>

    <view class="divider"></view>

    <view class="story-section story-section-bottom">
      <view class="story-line">只有真正的自然探索者，</view>
      <view class="story-line">才能帮助它们恢复记忆。</view>
    </view>
  </view>

  <!-- 底部操作区 -->
  <view class="action-area">
    <view class="button-decoration decoration-left">❧</view>

    <button class="start-button" bindtap="startExplore">
      开始第一次探索
    </button>

    <view class="button-decoration decoration-right">❧</view>

    <view class="hint">
      你的第一个任务正在等待
    </view>
  </view>

  <!-- 底部树叶剪影 -->
  <view class="bottom-leaves">
    <view class="bottom-leaf leaf-left-one"></view>
    <view class="bottom-leaf leaf-left-two"></view>
    <view class="bottom-leaf leaf-right-one"></view>
    <view class="bottom-leaf leaf-right-two"></view>
  </view>
</view>