page {
  background: #081c15;
}

.page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 120rpx 48rpx 80rpx;
  box-sizing: border-box;
  background:
    linear-gradient(
      180deg,
      #071a14 0%,
      #0b2b20 55%,
      #123b2b 100%
    );
}

.content {
  position: relative;
  z-index: 2;
  display: flex;
  min-height: calc(100vh - 200rpx);
  flex-direction: column;
  align-items: center;
}

.brand {
  color: #f4d88a;
  font-size: 88rpx;
  font-weight: 800;
  letter-spacing: 18rpx;
  text-indent: 18rpx;
}

.subtitle {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
  letter-spacing: 6rpx;
}

.story-card {
  width: 100%;
  margin-top: 100rpx;
  padding: 58rpx 42rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(244, 216, 138, 0.28);
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, 0.24);
  text-align: center;
}

.symbol {
  font-size: 82rpx;
}

.headline {
  margin-top: 28rpx;
  color: #fff4cf;
  font-size: 40rpx;
  font-weight: 700;
}

.story {
  margin-top: 32rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 30rpx;
  line-height: 1.8;
}

.start-button {
  width: 100%;
  height: 108rpx;
  margin-top: auto;
  border: none;
  border-radius: 54rpx;
  background: #f4d35e;
  color: #173b2b;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 108rpx;
  box-shadow: 0 20rpx 44rpx rgba(244, 211, 94, 0.24);
}

.start-button::after {
  border: none;
}

.hint {
  margin-top: 26rpx;
  color: rgba(255, 255, 255, 0.52);
  font-size: 24rpx;
}

.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(10rpx);
}

.glow-one {
  top: -140rpx;
  right: -100rpx;
  width: 360rpx;
  height: 360rpx;
  background: rgba(68, 180, 116, 0.18);
}

.glow-two {
  bottom: 100rpx;
  left: -140rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(244, 211, 94, 0.1);
}